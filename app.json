{
  "expo": {
    "name": "Campus Compass",
    "slug": "campuscompass",
    "scheme": "campuscompass",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#8B0000"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/favicon.png",
      "manifest": {
        "name": "Campus Compass",
        "short_name": "CampusCompass",
        "theme_color": "#8B0000",
        "background_color": "#ffffff",
        "display": "standalone",
        "start_url": "/",
        "icons": [
          {
            "src": "./assets/icon.png",
            "sizes": "512x512",
            "type": "image/png"
          },
          {
            "src": "./assets/apple-touch-icon.png",
            "sizes": "180x180",
            "type": "image/png"
          }
        ]
      }
    },
    "assetBundlePatterns": [
      "assets/*"
    ],
    "android": {
      "package": "com.vut.campuscompass",
      "versionCode": 2,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CALL_PHONE",
        "SEND_SMS"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Campus Compass to use your location for campus navigation and emergency sharing."
        }
      ],
      "expo-router",
      "expo-mlkit-ocr"
    ],
    "extra": {
      "eas": {
        "projectId": "632afc5f-2b8b-4ed8-80a6-ed7b1a6857cf"
      }
    }
  }
}
